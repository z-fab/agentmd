# Agent.md — Environment Configuration
# Copy this file to .env and fill in your keys

# --- Provider Credentials ---
GOOGLE_API_KEY=your-api-key-here
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# --- Paths (all optional — defaults shown as comments) ---
# AGENTMD_WORKSPACE=./workspace
# AGENTMD_AGENTS_DIR=./workspace/agents
# AGENTMD_OUTPUT_DIR=./workspace/output
# AGENTMD_DB_PATH=./data/agentmd.db
# AGENTMD_MCP_CONFIG=./workspace/agents/mcp-servers.json
